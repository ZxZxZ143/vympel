# Full-Docker local environment inventory. Copy this file to .env beside
# compose.yml and fill every blank. The working .env is ignored by Git.
SPRING_PROFILES_ACTIVE=local

VYMPEL_POSTGRES_HOST_PORT=
VYMPEL_REDIS_HOST_PORT=
VYMPEL_MINIO_API_HOST_PORT=
VYMPEL_MINIO_CONSOLE_HOST_PORT=
VYMPEL_BACKEND_HOST_PORT=
VYMPEL_PUBLIC_HOST_PORT=
VYMPEL_CRM_HOST_PORT=

VYMPEL_DB_NAME=
VYMPEL_DB_URL=
VYMPEL_DB_USERNAME=
VYMPEL_DB_PASSWORD=

VYMPEL_REDIS_URL=
VYMPEL_RATE_LIMIT_STORAGE=redis
VYMPEL_JWT_SECRET=
VYMPEL_RATE_LIMIT_HMAC_SECRET=

VYMPEL_S3_BUCKET=
VYMPEL_S3_REGION=
VYMPEL_S3_ENDPOINT=
VYMPEL_S3_PUBLIC_ENDPOINT=
VYMPEL_S3_ACCESS_KEY=
VYMPEL_S3_SECRET_KEY=
VYMPEL_S3_PATH_STYLE=true

VYMPEL_CORS_ALLOWED_ORIGINS=
VYMPEL_CRM_REFRESH_COOKIE_SECURE=false

VYMPEL_CMS_PUBLIC_REVALIDATE_ENABLED=true
VYMPEL_CMS_REVALIDATE_REQUIRED=true
VYMPEL_CMS_PUBLIC_REVALIDATE_URL=
VYMPEL_CMS_REVALIDATE_SECRET=
VYMPEL_CMS_MEDIA_CLEANUP_ENABLED=false

# Optional ADMIN bootstrap. Local may enable it explicitly. Staging and
# production stay disabled by default and use only temporary secret injection
# for a controlled first deployment; disable it immediately afterward.
VYMPEL_BOOTSTRAP_ADMIN_ENABLED=false
VYMPEL_BOOTSTRAP_ADMIN_EMAIL=
VYMPEL_BOOTSTRAP_ADMIN_PASSWORD=
VYMPEL_BOOTSTRAP_ADMIN_NAME=

# Container/server and browser-facing frontend values are deliberately separate.
BASE_API_PUBLIC=
NEXT_PUBLIC_BASE_API_PUBLIC=
NEXT_PUBLIC_CRM_API_BASE=
NEXT_PUBLIC_MEDIA_ORIGINS=
# Browser-safe canonical storefront origin. Required at storefront image build time.
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_TELEMETRY_ENABLED=false
TELEMETRY_ENABLED=false
