# Public storefront API origin. Use the deployed HTTPS backend origin outside local development.
BASE_API_PUBLIC=https://api.example.com/api/public
NEXT_PUBLIC_BASE_API_PUBLIC=https://api.example.com/api/public
NEXT_PUBLIC_MEDIA_ORIGINS=https://media.example.com
# Browser-safe canonical storefront origin. Required during `next build` and image build.
NEXT_PUBLIC_SITE_URL=https://shop.example.com

# CSP is enforced unless an explicitly monitored staging rollout uses report-only.
SECURITY_HEADERS_CSP_MODE=enforce
SECURITY_HEADERS_CSP_REPORT_URI=

# First-party telemetry is opt-in on both client and server. Production logs retain these records for 30 days.
NEXT_PUBLIC_TELEMETRY_ENABLED=false
NEXT_PUBLIC_TELEMETRY_SAMPLE_RATE=0.1
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_APP_RELEASE=unknown
TELEMETRY_ENABLED=false

# Server-only secret used by the Next.js revalidation route. Never expose it through NEXT_PUBLIC_*.
CMS_REVALIDATE_SECRET=<replace-with-a-long-random-secret>

# Local Docker/hybrid equivalents are documented in the workspace-root
# .env.example. BASE_API_PUBLIC is container-internal in Compose, while the
# NEXT_PUBLIC value must remain browser-accessible through localhost.
