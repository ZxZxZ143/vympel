# Copy to staging.env (ignored by Git), replace every REPLACE_ME value, and
# deploy only images built for the public URLs below.
REGISTRY=registry.example.invalid/vympel
RELEASE_TAG=0000000000000000000000000000000000000000
COMPOSE_PROJECT_NAME=vympel-staging

STOREFRONT_DOMAIN=shop.staging.example.invalid
CRM_DOMAIN=crm.staging.example.invalid
API_DOMAIN=api.staging.example.invalid
TLS_CERT_DIR=/REPLACE_ME/absolute/tls-directory
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443

SPRING_PROFILES_ACTIVE=staging
VYMPEL_DB_URL=jdbc:postgresql://postgres.staging.example.invalid:5432/vympel
VYMPEL_DB_USERNAME=REPLACE_ME_DATABASE_USER
VYMPEL_DB_PASSWORD=REPLACE_ME_DATABASE_PASSWORD
VYMPEL_JWT_SECRET=REPLACE_ME_AT_LEAST_48_RANDOM_CHARACTERS_FOR_JWT_SIGNING
VYMPEL_RATE_LIMIT_HMAC_SECRET=REPLACE_ME_DIFFERENT_48_RANDOM_CHARACTERS_FOR_LIMITER_HMAC
VYMPEL_RATE_LIMIT_STORAGE=redis
VYMPEL_REDIS_URL=rediss://:REPLACE_ME_REDIS_PASSWORD@redis.staging.example.invalid:6380
VYMPEL_TRUSTED_PROXY_CIDRS=10.0.0.0/8
VYMPEL_S3_BUCKET=REPLACE_ME_STAGING_BUCKET
VYMPEL_S3_REGION=REPLACE_ME_REGION
VYMPEL_S3_ENDPOINT=https://objects.staging.example.invalid
VYMPEL_S3_PUBLIC_ENDPOINT=https://media.staging.example.invalid
VYMPEL_S3_ACCESS_KEY=REPLACE_ME_STORAGE_ACCESS_KEY
VYMPEL_S3_SECRET_KEY=REPLACE_ME_STORAGE_SECRET_KEY
VYMPEL_S3_PATH_STYLE=false
VYMPEL_CORS_ALLOWED_ORIGINS=https://shop.staging.example.invalid,https://crm.staging.example.invalid
VYMPEL_CRM_REFRESH_COOKIE_SECURE=true
VYMPEL_CRM_REFRESH_COOKIE_SAME_SITE=Lax
VYMPEL_ALLOW_LOCALHOST_SERVICES=false
VYMPEL_ALLOW_INSECURE_SERVICE_TRANSPORT=false

VYMPEL_CMS_PUBLIC_REVALIDATE_ENABLED=true
VYMPEL_CMS_REVALIDATE_REQUIRED=true
VYMPEL_CMS_PUBLIC_REVALIDATE_URL=https://shop.staging.example.invalid/api/revalidate
VYMPEL_CMS_REVALIDATE_SECRET=REPLACE_ME_AT_LEAST_48_RANDOM_CHARACTERS_FOR_CMS_HMAC
VYMPEL_CMS_MEDIA_CLEANUP_ENABLED=false
VYMPEL_ANALYTICS_CLEANUP_ENABLED=true
VYMPEL_ANALYTICS_CLEANUP_DRY_RUN=true

# Disabled by default. Supply temporary values only for a controlled initial setup.
VYMPEL_BOOTSTRAP_ADMIN_ENABLED=false
VYMPEL_BOOTSTRAP_ADMIN_EMAIL=
VYMPEL_BOOTSTRAP_ADMIN_PASSWORD=
VYMPEL_BOOTSTRAP_ADMIN_NAME=

# BASE_API_PUBLIC is server-side/container-internal. NEXT_PUBLIC values are
# compiled into each image by the image-release workflow and must match here.
BASE_API_PUBLIC=http://backend:8080/api/public
NEXT_PUBLIC_BASE_API_PUBLIC=https://api.staging.example.invalid/api/public
NEXT_PUBLIC_CRM_API_BASE=https://api.staging.example.invalid/api/crm
NEXT_PUBLIC_MEDIA_ORIGINS=https://media.staging.example.invalid
NEXT_PUBLIC_APP_ENV=staging
NEXT_PUBLIC_APP_RELEASE=0000000000000000000000000000000000000000
NEXT_PUBLIC_TELEMETRY_ENABLED=false
TELEMETRY_ENABLED=false

STOREFRONT_HEALTH_URL=https://shop.staging.example.invalid/ru
CRM_HEALTH_URL=https://crm.staging.example.invalid/login
API_HEALTH_URL=https://api.staging.example.invalid/api/public/ping
MIGRATION_TIMEOUT_SECONDS=300
HEALTH_TIMEOUT_SECONDS=180
