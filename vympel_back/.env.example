# Non-local runtime configuration. Values below are placeholders, not credentials.
SPRING_PROFILES_ACTIVE=production
VYMPEL_DB_URL=jdbc:postgresql://db.example.internal:5432/vympel
VYMPEL_DB_USERNAME=<database-user>
VYMPEL_DB_PASSWORD=<strong-database-password>
VYMPEL_JWT_SECRET=<at-least-48-random-characters>
VYMPEL_RATE_LIMIT_HMAC_SECRET=<different-at-least-48-random-characters>
VYMPEL_RATE_LIMIT_STORAGE=redis
VYMPEL_REDIS_URL=rediss://:<redis-password>@redis.example.internal:6380
VYMPEL_TRUSTED_PROXY_CIDRS=<ingress-cidr-list>
VYMPEL_S3_BUCKET=<bucket>
VYMPEL_S3_REGION=<region>
VYMPEL_S3_ENDPOINT=https://objects.example.com
VYMPEL_S3_PUBLIC_ENDPOINT=https://media.example.com
VYMPEL_S3_ACCESS_KEY=<access-key>
VYMPEL_S3_SECRET_KEY=<secret-key>
VYMPEL_S3_API_CALL_TIMEOUT=10s
VYMPEL_S3_API_ATTEMPT_TIMEOUT=5s
VYMPEL_SLOW_OPERATION_THRESHOLD_MS=500
VYMPEL_CORS_ALLOWED_ORIGINS=https://shop.example.com,https://crm.example.com
VYMPEL_CRM_REFRESH_COOKIE_SECURE=true
VYMPEL_BOOTSTRAP_ADMIN_ENABLED=false
VYMPEL_BOOTSTRAP_ADMIN_EMAIL=
VYMPEL_BOOTSTRAP_ADMIN_PASSWORD=
VYMPEL_BOOTSTRAP_ADMIN_NAME=
VYMPEL_CMS_REVALIDATE_REQUIRED=true
VYMPEL_CMS_PUBLIC_REVALIDATE_ENABLED=true
VYMPEL_CMS_PUBLIC_REVALIDATE_URL=https://shop.example.com/api/revalidate
VYMPEL_CMS_REVALIDATE_SECRET=<cms-revalidation-secret>
VYMPEL_CMS_PUBLIC_REVALIDATE_TIMEOUT_MS=3000
VYMPEL_CMS_PUBLIC_REVALIDATE_MAX_ATTEMPTS=8
VYMPEL_CMS_PUBLIC_REVALIDATE_RETRY_BASE_DELAY=5s
VYMPEL_CMS_PUBLIC_REVALIDATE_RETRY_MAX_DELAY=5m
VYMPEL_CMS_PUBLIC_REVALIDATE_RETRY_POLL_MS=5000
VYMPEL_CMS_PUBLIC_REVALIDATE_RETRY_BATCH_SIZE=20
VYMPEL_CMS_PUBLIC_REVALIDATE_STALE_CLAIM_TIMEOUT=2m
VYMPEL_CMS_MEDIA_CLEANUP_GRACE_PERIOD=24h
VYMPEL_CMS_MEDIA_CLEANUP_ENABLED=true
VYMPEL_CMS_MEDIA_CLEANUP_CRON=0 30 3 * * *
VYMPEL_CMS_MEDIA_CLEANUP_BATCH_SIZE=25
VYMPEL_CMS_MEDIA_CLEANUP_MAX_BATCH_SIZE=100
VYMPEL_CMS_MEDIA_CLEANUP_RETRY_BASE_DELAY=5m
VYMPEL_CMS_MEDIA_CLEANUP_RETRY_MAX_DELAY=6h
VYMPEL_CMS_MEDIA_CLEANUP_STALE_CLAIM_TIMEOUT=15m

# Privacy-minimized product analytics events are retained for 180 days.
# Set dry-run=true before the first production cleanup to count candidates without deleting.
VYMPEL_ANALYTICS_RETENTION_DAYS=180
VYMPEL_ANALYTICS_CLEANUP_ENABLED=true
VYMPEL_ANALYTICS_CLEANUP_DRY_RUN=false
VYMPEL_ANALYTICS_CLEANUP_CRON=0 45 3 * * *
VYMPEL_ANALYTICS_CLEANUP_BATCH_SIZE=5000
VYMPEL_ANALYTICS_CLEANUP_MAX_BATCHES=20
