<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="2026-07-16-02-crm-refresh-token-hash-type" author="codex">
        <preConditions onFail="HALT" onError="HALT">
            <tableExists tableName="refresh_token_session"/>
            <columnExists tableName="refresh_token_session" columnName="token_hash"/>
        </preConditions>

        <comment>
            Uses VARCHAR(64) for the SHA-256 jti hex digest so PostgreSQL JDBC metadata matches the
            Hibernate String mapping. Fixed-width CHAR is unnecessary because the digest length is
            already enforced by the application and unique constraint.
        </comment>

        <modifyDataType
                tableName="refresh_token_session"
                columnName="token_hash"
                newDataType="VARCHAR(64)"/>

        <rollback>
            <modifyDataType
                    tableName="refresh_token_session"
                    columnName="token_hash"
                    newDataType="CHAR(64)"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
