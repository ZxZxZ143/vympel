<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="2026-07-08-01-cms-mobile-locale-media" author="codex" dbms="postgresql">
        <addColumn tableName="cms_block">
            <column name="mobile_media_kz_id" type="BIGINT"/>
            <column name="mobile_media_en_id" type="BIGINT"/>
        </addColumn>

        <addForeignKeyConstraint baseTableName="cms_block" baseColumnNames="mobile_media_kz_id"
                                 referencedTableName="cms_media" referencedColumnNames="id"
                                 constraintName="fk_cms_block_mobile_media_kz" onDelete="SET NULL"/>
        <addForeignKeyConstraint baseTableName="cms_block" baseColumnNames="mobile_media_en_id"
                                 referencedTableName="cms_media" referencedColumnNames="id"
                                 constraintName="fk_cms_block_mobile_media_en" onDelete="SET NULL"/>
    </changeSet>
</databaseChangeLog>
