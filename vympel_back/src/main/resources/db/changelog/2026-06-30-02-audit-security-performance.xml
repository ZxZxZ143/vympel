<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="2026-06-30-02-audit-indexes" author="codex">
        <createIndex tableName="product" indexName="idx_product_status_stock_created">
            <column name="status"/>
            <column name="stock_quantity"/>
            <column name="created_at"/>
        </createIndex>

        <createIndex tableName="media" indexName="idx_media_product_position">
            <column name="product_id"/>
            <column name="position"/>
        </createIndex>

        <createIndex tableName="product_review" indexName="idx_product_review_product_status_created_rating">
            <column name="product_id"/>
            <column name="status"/>
            <column name="created_at"/>
            <column name="rating"/>
        </createIndex>

        <createIndex tableName="product_analytics_event" indexName="idx_product_analytics_event_product_type_created">
            <column name="product_id"/>
            <column name="event_type"/>
            <column name="created_at"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
