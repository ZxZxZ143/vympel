{
  "name": "vympel-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:sharp-security": "node ../scripts/check-sharp-security.mjs",
    "test:security": "node --test --test-isolation=none scripts/test-security-headers.mjs",
    "test:budgets": "node ../scripts/check-performance-budgets.mjs",
    "test:budgets:ci": "node ../scripts/check-performance-budgets.mjs --require-build",
    "test:production-headers": "node scripts/test-production-headers.mjs"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "typescript": "^5",
    "vitest": "^3.2.7"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.20",
      "sharp": "^0.35.0"
    }
  }
}
